#!/usr/bin/env python3
import argparse,json
from pathlib import Path
from lab.phase2_ten_strategy_v2 import import_genuine_returned_package

parser=argparse.ArgumentParser()
parser.add_argument("package",type=Path)
parser.add_argument("execution_packet",type=Path)
args=parser.parse_args()
packet=json.loads(args.execution_packet.read_text(encoding="utf-8-sig"))
print(json.dumps(import_genuine_returned_package(args.package,packet),sort_keys=True,separators=(",",":")))
