#!/usr/bin/env python3
"""Capture and safely remove repository-attributable Phase-2 /tmp trees."""

from __future__ import annotations

import hashlib
import json
import os
from pathlib import Path
import re
import shutil
import stat
import subprocess
import sys
from datetime import datetime, timezone


ROOT = Path(__file__).resolve().parents[1]
TMP = Path("/tmp")
SCHEMA = "nora.phase2_linux_temporary_artifact_forensics_v1"
PATTERNS = ("nora-stage2-offline-preflight-*", "nora-reissue-*")
STAGE_RE = re.compile(r"^nora-stage2-offline-preflight-([0-9a-f]{7,40})(?:-|$)")


def die(message: str) -> None:
    raise SystemExit(message)


def git(*args: str, binary: bool = False) -> bytes | str:
    value = subprocess.check_output(("git", *args), cwd=ROOT, stderr=subprocess.DEVNULL)
    return value if binary else value.decode().strip()


def sha256_bytes(value: bytes) -> str:
    return hashlib.sha256(value).hexdigest()


def sha256_file(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as stream:
        for block in iter(lambda: stream.read(1024 * 1024), b""):
            digest.update(block)
    return digest.hexdigest()


def timestamp(value: float) -> str:
    return datetime.fromtimestamp(value, timezone.utc).isoformat().replace("+00:00", "Z")


def member_view(root: Path) -> list[dict[str, object]]:
    result: list[dict[str, object]] = []
    for path in sorted(root.rglob("*"), key=lambda item: item.as_posix()):
        details = path.lstat()
        if stat.S_ISLNK(details.st_mode):
            die(f"refusing symlink in temporary artifact: {path}")
        if not (stat.S_ISDIR(details.st_mode) or stat.S_ISREG(details.st_mode)):
            die(f"refusing special member in temporary artifact: {path}")
        relative = path.relative_to(root).as_posix()
        result.append(
            {
                "path": relative,
                "type": "directory" if path.is_dir() else "file",
                "mode": format(stat.S_IMODE(details.st_mode), "04o"),
                "uid": details.st_uid,
                "gid": details.st_gid,
                "size": None if path.is_dir() else details.st_size,
                "sha256": None if path.is_dir() else sha256_file(path),
                "created_or_metadata_changed_utc": timestamp(details.st_ctime),
                "modified_utc": timestamp(details.st_mtime),
            }
        )
    return result


def expected_path(relative: str, reissue: bool) -> str:
    base = "tests/fixtures/phase2_ten_strategy_suite/native_v2_runner_final/"
    if reissue:
        return base + relative
    if relative in {"execution_packet.json", "final_batch.json"} or relative.startswith("compile/"):
        return base + relative
    return relative


def packet_identity_at(commit: str) -> str | None:
    path = "tests/fixtures/phase2_ten_strategy_suite/native_v2_runner_final/execution_packet.json"
    try:
        value = git("show", f"{commit}:{path}", binary=True)
    except subprocess.CalledProcessError:
        return None
    return json.loads(value)["execution_packet_identity"]


def commit_for_reissue(root: Path) -> tuple[str, str]:
    identity = json.loads((root / "execution_packet.json").read_text())["execution_packet_identity"]
    candidates: list[str] = []
    for commit in str(git("rev-list", "--all")).splitlines():
        if packet_identity_at(commit) == identity:
            candidates.append(commit)
    if not candidates:
        die(f"no repository commit owns reissue packet identity {identity}")
    return candidates[0], identity


def classify(root: Path) -> dict[str, object]:
    details = root.lstat()
    if not stat.S_ISDIR(details.st_mode) or stat.S_ISLNK(details.st_mode):
        die(f"temporary artifact root is not a real directory: {root}")
    if details.st_uid != os.getuid():
        die(f"temporary artifact has unexpected owner: {root}")
    stage_match = STAGE_RE.match(root.name)
    reissue = root.name.startswith("nora-reissue-")
    if stage_match:
        commit = str(git("rev-parse", f"{stage_match.group(1)}^{{commit}}"))
        identity = json.loads((root / "execution_packet.json").read_text())["execution_packet_identity"]
    elif reissue:
        commit, identity = commit_for_reissue(root)
    else:
        die(f"unrecognized temporary artifact name: {root}")
    members = member_view(root)
    mismatches: list[dict[str, str]] = []
    file_count = 0
    for member in members:
        if member["type"] != "file":
            continue
        file_count += 1
        repository_path = expected_path(str(member["path"]), reissue)
        try:
            expected = git("show", f"{commit}:{repository_path}", binary=True)
            expected_hash = sha256_bytes(expected)
        except subprocess.CalledProcessError:
            expected_hash = "missing"
        if expected_hash != member["sha256"]:
            mismatches.append(
                {
                    "path": str(member["path"]),
                    "repository_path": repository_path,
                    "actual_sha256": str(member["sha256"]),
                    "expected_sha256": expected_hash,
                }
            )
    if mismatches:
        die(f"ambiguous temporary artifact bytes in {root}: {json.dumps(mismatches)}")
    return {
        "path": str(root),
        "name_classification": "repository_offline_preflight_stage" if stage_match else "repository_execution_packet_reissue",
        "repository_attributed": True,
        "attribution_basis": "every file byte-identical to its mapped path at the resolved repository commit",
        "resolved_commit": commit,
        "execution_packet_identity": identity,
        "owner_uid": details.st_uid,
        "owner_gid": details.st_gid,
        "mode": format(stat.S_IMODE(details.st_mode), "04o"),
        "created_or_metadata_changed_utc": timestamp(details.st_ctime),
        "modified_utc": timestamp(details.st_mtime),
        "file_count": file_count,
        "members": members,
        "mismatches": mismatches,
    }


def atomic_json(path: Path, value: object) -> None:
    if path.exists():
        die(f"refusing to replace durable report: {path}")
    path.parent.mkdir(parents=True, exist_ok=True)
    temporary = path.with_name(path.name + f".partial.{os.getpid()}")
    temporary.write_text(json.dumps(value, indent=2, sort_keys=True) + "\n")
    os.replace(temporary, path)


def capture(report_path: Path) -> None:
    roots = sorted({path for pattern in PATTERNS for path in TMP.glob(pattern)}, key=lambda path: path.name)
    artifacts = [classify(path) for path in roots]
    report = {
        "schema_version": SCHEMA,
        "classification": "ALL_MATCHING_ARTIFACTS_REPOSITORY_ATTRIBUTED",
        "captured_utc": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
        "repository_root": str(ROOT),
        "repository_head_at_capture": git("rev-parse", "HEAD"),
        "patterns": list(PATTERNS),
        "artifact_count": len(artifacts),
        "ambiguous_artifacts": [],
        "cleanup_authorized_paths": [artifact["path"] for artifact in artifacts],
        "artifacts": artifacts,
    }
    atomic_json(report_path, report)
    print(json.dumps({"report": str(report_path), "artifact_count": len(artifacts)}, sort_keys=True))


def cleanup(capture_path: Path, cleanup_path: Path) -> None:
    capture_record = json.loads(capture_path.read_text())
    if capture_record.get("schema_version") != SCHEMA or capture_record.get("ambiguous_artifacts") != []:
        die("untrusted or ambiguous temporary-artifact capture")
    removed: list[dict[str, object]] = []
    for artifact in capture_record["artifacts"]:
        path = Path(artifact["path"])
        current = classify(path)
        captured_files = {item["path"]: item["sha256"] for item in artifact["members"] if item["type"] == "file"}
        current_files = {item["path"]: item["sha256"] for item in current["members"] if item["type"] == "file"}
        if current_files != captured_files or not current["repository_attributed"]:
            die(f"temporary artifact changed after capture: {path}")
        shutil.rmtree(path)
        if path.exists():
            die(f"temporary artifact cleanup incomplete: {path}")
        removed.append({"path": str(path), "file_count": current["file_count"], "removed": True})
    cleanup_record = {
        "schema_version": "nora.phase2_linux_temporary_artifact_cleanup_v1",
        "capture_report": str(capture_path),
        "capture_report_sha256": sha256_file(capture_path),
        "removed": removed,
        "removed_count": len(removed),
        "unrelated_paths_touched": [],
        "completed_utc": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
    }
    atomic_json(cleanup_path, cleanup_record)
    print(json.dumps({"report": str(cleanup_path), "removed_count": len(removed)}, sort_keys=True))


def main() -> None:
    if len(sys.argv) == 3 and sys.argv[1] == "capture":
        capture((ROOT / sys.argv[2]).resolve())
    elif len(sys.argv) == 4 and sys.argv[1] == "cleanup":
        cleanup((ROOT / sys.argv[2]).resolve(), (ROOT / sys.argv[3]).resolve())
    else:
        die("usage: phase2-linux-temp-forensics capture REPORT | cleanup CAPTURE_REPORT CLEANUP_REPORT")


if __name__ == "__main__":
    main()
