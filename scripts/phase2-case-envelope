#!/usr/bin/env python3
import argparse, json, sys
from pathlib import Path
from lab.phase2_case_envelope import CaseEnvelopeError, publish, verify

p=argparse.ArgumentParser(); s=p.add_subparsers(dest="action",required=True)
b=s.add_parser("publish"); b.add_argument("--plan",type=Path,required=True); b.add_argument("--destination",type=Path,required=True)
v=s.add_parser("verify"); v.add_argument("--envelope",type=Path,required=True); v.add_argument("--sha256")
a=p.parse_args()
try:
    if a.action=="publish": print(publish(json.loads(a.plan.read_bytes()),a.destination))
    else: print(json.dumps(verify(a.envelope,a.sha256),sort_keys=True))
except (CaseEnvelopeError,OSError,KeyError,json.JSONDecodeError) as e:
    print(f"case-envelope-error: {e}",file=sys.stderr); raise SystemExit(1)
