#!/usr/bin/env bash
set -euo pipefail
mode=${1:-}
if [[ $mode == run && $# -eq 12 ]]; then
  staged=$2; run_id=$3; symbol=$4; remote_incoming=$5; local_raw=$6
  [[ -d $staged && ! -e $local_raw ]] || { echo 'invalid or occupied path' >&2; exit 2; }
  ssh nora-win10 "powershell -NoProfile -Command \"if(Test-Path -LiteralPath '$remote_incoming'){throw 'occupied remote incoming'};New-Item -ItemType Directory -Path '$remote_incoming'|Out-Null\""
  scp -r "$staged/." "nora-win10:$remote_incoming/"
  remote_run=$(ssh nora-win10 "powershell -NoProfile -File '$remote_incoming/phase-0a-h/windows/execute-ten-strategy-packet.ps1' -IncomingRoot '$remote_incoming' -RunId '$run_id' -Symbol '$symbol' -BeforeBarCount '$7' -AfterBarCount '$8' -BeforeEarliest '$9' -BeforeLatest '${10}' -AfterEarliest '${11}' -AfterLatest '${12}'")
  partial="$local_raw.partial"; [[ ! -e $partial ]] || { echo 'occupied local partial path' >&2; exit 2; }
  scp -r "nora-win10:$remote_run" "$partial"; mv "$partial" "$local_raw"
  printf '%s\n' "$remote_run"
elif [[ $mode == package && $# -eq 5 ]]; then
  remote_run=$2; evaluation=$3; local_return=$4; remote_incoming=$5
  [[ -f $evaluation && ! -e $local_return ]] || { echo 'missing evaluation or occupied result' >&2; exit 2; }
  scp "$evaluation" "nora-win10:$remote_run/environmental-evaluation.json"
  ssh nora-win10 "powershell -NoProfile -File '$remote_incoming/phase-0a-h/windows/build-ten-strategy-returned-package.ps1' -RunDirectory '$remote_run' -Destination '$remote_run.returned'"
  partial="$local_return.partial"; [[ ! -e $partial ]] || { echo 'occupied local partial path' >&2; exit 2; }
  scp -r "nora-win10:$remote_run.returned" "$partial"; mv "$partial" "$local_return"
else
  echo "usage: $0 run STAGED RUN_ID SYMBOL REMOTE_INCOMING LOCAL_RAW BEFORE_COUNT AFTER_COUNT BEFORE_EARLIEST BEFORE_LATEST AFTER_EARLIEST AFTER_LATEST" >&2
  echo "   or: $0 package REMOTE_RUN ENVIRONMENTAL_EVALUATION LOCAL_RETURN REMOTE_INCOMING" >&2
  exit 2
fi
