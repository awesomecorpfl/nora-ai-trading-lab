#property strict
#include "NoraPhase2KamaRuntimeV1.mqh"
int OnInit(){int f=FileOpen("nora_phase2_kama_v1.csv",FILE_WRITE|FILE_CSV|FILE_ANSI,'\t');if(f==INVALID_HANDLE){Print("NORA_PHASE2_KAMA_FAIL_V1");return INIT_FAILED;}FileWrite(f,"scenario_id","node","output","row","timestamp","value","null","classification","reason_code");double x0[8]={10,11,13,12,15,14,18,17};string t0[8]={"2026-04-01T00:00:00Z","2026-04-01T00:01:00Z","2026-04-01T00:02:00Z","2026-04-01T00:03:00Z","2026-04-01T00:04:00Z","2026-04-01T00:05:00Z","2026-04-01T00:06:00Z","2026-04-01T00:07:00Z"};double k0[];bool v0[];if(!NoraKamaCompute(x0,8,3,k0,v0)){FileClose(f);Print("NORA_PHASE2_KAMA_FAIL_V1");return INIT_FAILED;}for(int j=0;j<8;j++){FileWrite(f,"adaptive_trend","KAMA","value",j,t0[j],v0[j]?DoubleToString(k0[j],17):"NULL",v0[j]?"false":"true",v0[j]?"steady_state":"warmup_or_null",v0[j]?"ok":"warmup");}double x1[6]={7,7,7,7,7,7};string t1[6]={"2026-04-02T00:00:00Z","2026-04-02T00:01:00Z","2026-04-02T00:02:00Z","2026-04-02T00:03:00Z","2026-04-02T00:04:00Z","2026-04-02T00:05:00Z"};double k1[];bool v1[];if(!NoraKamaCompute(x1,6,3,k1,v1)){FileClose(f);Print("NORA_PHASE2_KAMA_FAIL_V1");return INIT_FAILED;}for(int j=0;j<6;j++){FileWrite(f,"flat_series","KAMA","value",j,t1[j],v1[j]?DoubleToString(k1[j],17):"NULL",v1[j]?"false":"true",v1[j]?"steady_state":"warmup_or_null",v1[j]?"ok":"warmup");}FileWrite(f,"invalid_period","KAMA","value","NULL","NULL","NULL","true","invalid_input","invalid_period");FileClose(f);Print("NORA_PHASE2_KAMA_COMPLETE_V1");return INIT_SUCCEEDED;}
void OnDeinit(const int reason){}
