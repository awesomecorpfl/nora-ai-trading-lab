#property strict
#include "NoraPhase2SessionOHLCRuntimeV1.mqh"
int OnInit(){int f=FileOpen("nora_phase2_session_ohlc_v1.csv",FILE_WRITE|FILE_CSV|FILE_ANSI|FILE_COMMON,'\t');if(f==INVALID_HANDLE){Print("NORA_PHASE2_SESSION_OHLC_FAIL_V1");return INIT_FAILED;}FileWrite(f,"scenario_id","node","output","row","timestamp","value","null","classification","reason_code");string sid0[5]={"A","A","A","B","B"};string t0[5]={"2026-06-01T00:00:00Z","2026-06-01T00:01:00Z","2026-06-01T00:02:00Z","2026-06-02T00:00:00Z","2026-06-02T00:01:00Z"};double o0[5]={10,11,9,20,21};double h0[5]={12,14,13,22,25};double l0[5]={8,10,7,18,19};double c0[5]={11,13,10,21,24};double v0[];if(!NoraSessionOHLCCompute(sid0,o0,h0,l0,c0,5,0,v0)){FileClose(f);Print("NORA_PHASE2_SESSION_OHLC_FAIL_V1");return INIT_FAILED;}for(int j=0;j<5;j++)FileWrite(f,"two_sessions","SessionOHLC","open",j,t0[j],DoubleToString(v0[j],17),"false","steady_state","ok");string sid1[5]={"A","A","A","B","B"};string t1[5]={"2026-06-01T00:00:00Z","2026-06-01T00:01:00Z","2026-06-01T00:02:00Z","2026-06-02T00:00:00Z","2026-06-02T00:01:00Z"};double o1[5]={10,11,9,20,21};double h1[5]={12,14,13,22,25};double l1[5]={8,10,7,18,19};double c1[5]={11,13,10,21,24};double v1[];if(!NoraSessionOHLCCompute(sid1,o1,h1,l1,c1,5,1,v1)){FileClose(f);Print("NORA_PHASE2_SESSION_OHLC_FAIL_V1");return INIT_FAILED;}for(int j=0;j<5;j++)FileWrite(f,"two_sessions","SessionOHLC","high",j,t1[j],DoubleToString(v1[j],17),"false","steady_state","ok");string sid2[5]={"A","A","A","B","B"};string t2[5]={"2026-06-01T00:00:00Z","2026-06-01T00:01:00Z","2026-06-01T00:02:00Z","2026-06-02T00:00:00Z","2026-06-02T00:01:00Z"};double o2[5]={10,11,9,20,21};double h2[5]={12,14,13,22,25};double l2[5]={8,10,7,18,19};double c2[5]={11,13,10,21,24};double v2[];if(!NoraSessionOHLCCompute(sid2,o2,h2,l2,c2,5,2,v2)){FileClose(f);Print("NORA_PHASE2_SESSION_OHLC_FAIL_V1");return INIT_FAILED;}for(int j=0;j<5;j++)FileWrite(f,"two_sessions","SessionOHLC","low",j,t2[j],DoubleToString(v2[j],17),"false","steady_state","ok");string sid3[5]={"A","A","A","B","B"};string t3[5]={"2026-06-01T00:00:00Z","2026-06-01T00:01:00Z","2026-06-01T00:02:00Z","2026-06-02T00:00:00Z","2026-06-02T00:01:00Z"};double o3[5]={10,11,9,20,21};double h3[5]={12,14,13,22,25};double l3[5]={8,10,7,18,19};double c3[5]={11,13,10,21,24};double v3[];if(!NoraSessionOHLCCompute(sid3,o3,h3,l3,c3,5,3,v3)){FileClose(f);Print("NORA_PHASE2_SESSION_OHLC_FAIL_V1");return INIT_FAILED;}for(int j=0;j<5;j++)FileWrite(f,"two_sessions","SessionOHLC","close",j,t3[j],DoubleToString(v3[j],17),"false","steady_state","ok");FileClose(f);Print("NORA_PHASE2_SESSION_OHLC_COMPLETE_V1");return INIT_SUCCEEDED;}
void OnDeinit(const int reason){}
