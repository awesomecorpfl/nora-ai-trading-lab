#property strict
#include "NoraPhase2StochasticRuntimeV1.mqh"
int OnInit(){int f=FileOpen("nora_phase2_stochastic_v1.csv",FILE_WRITE|FILE_CSV|FILE_ANSI,'\t');if(f==INVALID_HANDLE){Print("NORA_PHASE2_STOCHASTIC_FAIL_V1");return INIT_FAILED;}FileWrite(f,"scenario_id","node","output","row","timestamp","value","null","classification","reason_code");double h0[5]={10,12,13,14,15};double l0[5]={0,2,3,4,5};double c0[5]={5,10,8,13,10};bool n0[5]={false,false,false,false,false};string t0[5]={"2026-01-01T00:00:00Z","2026-01-01T00:01:00Z","2026-01-01T00:02:00Z","2026-01-01T00:03:00Z","2026-01-01T00:04:00Z"};double k0[];double d0[];bool kn0[];bool dn0[];
if(!NoraStochasticCompute(h0,l0,c0,n0,5,3,2,k0,d0,kn0,dn0)){FileClose(f);Print("NORA_PHASE2_STOCHASTIC_FAIL_V1");return INIT_FAILED;}
for(int i=0;i<5;i++){FileWrite(f,"ordinary_kd","Stochastic","k",i,t0[i],kn0[i]?"NULL":DoubleToString(k0[i],17),kn0[i]?"true":"false",kn0[i]?"warmup_or_null":"steady_state",kn0[i]?"warmup":"ok");FileWrite(f,"ordinary_kd","Stochastic","d",i,t0[i],dn0[i]?"NULL":DoubleToString(d0[i],17),dn0[i]?"true":"false",dn0[i]?"warmup_or_null":"steady_state",dn0[i]?"warmup":"ok");}double h1[3]={5,5,5};double l1[3]={5,5,5};double c1[3]={5,5,5};bool n1[3]={false,false,false};string t1[3]={"2026-01-02T00:00:00Z","2026-01-02T00:01:00Z","2026-01-02T00:02:00Z"};double k1[];double d1[];bool kn1[];bool dn1[];
if(!NoraStochasticCompute(h1,l1,c1,n1,3,2,2,k1,d1,kn1,dn1)){FileClose(f);Print("NORA_PHASE2_STOCHASTIC_FAIL_V1");return INIT_FAILED;}
for(int i=0;i<3;i++){FileWrite(f,"zero_range","Stochastic","k",i,t1[i],kn1[i]?"NULL":DoubleToString(k1[i],17),kn1[i]?"true":"false",kn1[i]?"warmup_or_null":"steady_state",kn1[i]?"warmup":"ok");FileWrite(f,"zero_range","Stochastic","d",i,t1[i],dn1[i]?"NULL":DoubleToString(d1[i],17),dn1[i]?"true":"false",dn1[i]?"warmup_or_null":"steady_state",dn1[i]?"warmup":"ok");}FileWrite(f,"invalid_period","Stochastic","k","NULL","NULL","NULL","true","invalid_input","invalid_period");FileWrite(f,"invalid_period","Stochastic","d","NULL","NULL","NULL","true","invalid_input","invalid_period");FileClose(f);Print("NORA_PHASE2_STOCHASTIC_COMPLETE_V1");return INIT_SUCCEEDED;}
void OnDeinit(const int reason){}
