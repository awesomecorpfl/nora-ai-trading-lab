#property strict
#include "NoraPhase2Layer1BatchRuntimeV1.mqh"
int OnInit(){int f=FileOpen("nora_phase2_layer1_batch_v1.csv",FILE_WRITE|FILE_CSV|FILE_ANSI,'\t');if(f==INVALID_HANDLE){Print("NORA_PHASE2_LAYER1_BATCH_FAIL_V1");return INIT_FAILED;}FileWrite(f,"scenario_id","node","output","row","timestamp","value","null","classification","reason_code");
double v0[6]={1,2,4,3,5,6};bool n0[6]={false,false,false,false,false,false};string t0[6]={"t0","t1","t2","t3","t4","t5"};double o0[];bool z0[];
if(!NoraLayer1Compute(0,v0,n0,6,3,o0,z0)){FileClose(f);Print("NORA_PHASE2_LAYER1_BATCH_FAIL_V1");return INIT_FAILED;}
for(int i=0;i<6;i++){string reason=!z0[i]?"ok":(n0[i]?"null_input":"warmup");string phase=!z0[i]?"steady_state":"warmup_or_null";FileWrite(f,"ema_ordinary_p3","EMA","value",i,t0[i],z0[i]?"NULL":DoubleToString(o0[i],17),z0[i]?"true":"false",phase,reason);}double v1[5]={7,7,7,7,7};bool n1[5]={false,false,false,false,false};string t1[5]={"t0","t1","t2","t3","t4"};double o1[];bool z1[];
if(!NoraLayer1Compute(0,v1,n1,5,3,o1,z1)){FileClose(f);Print("NORA_PHASE2_LAYER1_BATCH_FAIL_V1");return INIT_FAILED;}
for(int i=0;i<5;i++){string reason=!z1[i]?"ok":(n1[i]?"null_input":"warmup");string phase=!z1[i]?"steady_state":"warmup_or_null";FileWrite(f,"ema_flat_p3","EMA","value",i,t1[i],z1[i]?"NULL":DoubleToString(o1[i],17),z1[i]?"true":"false",phase,reason);}double v2[6]={1,2,0.0,4,6,8};bool n2[6]={false,false,true,false,false,false};string t2[6]={"t0","t1","t2","t3","t4","t5"};double o2[];bool z2[];
if(!NoraLayer1Compute(0,v2,n2,6,2,o2,z2)){FileClose(f);Print("NORA_PHASE2_LAYER1_BATCH_FAIL_V1");return INIT_FAILED;}
for(int i=0;i<6;i++){string reason=!z2[i]?"ok":(n2[i]?"null_input":"warmup");string phase=!z2[i]?"steady_state":"warmup_or_null";FileWrite(f,"ema_null_reset_p2","EMA","value",i,t2[i],z2[i]?"NULL":DoubleToString(o2[i],17),z2[i]?"true":"false",phase,reason);}double v3[3]={3,2,1};bool n3[3]={false,false,false};string t3[3]={"t0","t1","t2"};double o3[];bool z3[];
if(!NoraLayer1Compute(0,v3,n3,3,1,o3,z3)){FileClose(f);Print("NORA_PHASE2_LAYER1_BATCH_FAIL_V1");return INIT_FAILED;}
for(int i=0;i<3;i++){string reason=!z3[i]?"ok":(n3[i]?"null_input":"warmup");string phase=!z3[i]?"steady_state":"warmup_or_null";FileWrite(f,"ema_minimum_p1","EMA","value",i,t3[i],z3[i]?"NULL":DoubleToString(o3[i],17),z3[i]?"true":"false",phase,reason);}double v4[6]={2,2,2,1,3,3};bool n4[6]={false,false,false,false,false,false};string t4[6]={"t0","t1","t2","t3","t4","t5"};double o4[];bool z4[];
if(!NoraLayer1Compute(1,v4,n4,6,3,o4,z4)){FileClose(f);Print("NORA_PHASE2_LAYER1_BATCH_FAIL_V1");return INIT_FAILED;}
for(int i=0;i<6;i++){string reason=!z4[i]?"ok":(n4[i]?"null_input":"warmup");string phase=!z4[i]?"steady_state":"warmup_or_null";FileWrite(f,"highest_repeated_p3","Highest","value",i,t4[i],z4[i]?"NULL":DoubleToString(o4[i],17),z4[i]?"true":"false",phase,reason);}double v5[5]={1,0.0,4,3,5};bool n5[5]={false,true,false,false,false};string t5[5]={"t0","t1","t2","t3","t4"};double o5[];bool z5[];
if(!NoraLayer1Compute(1,v5,n5,5,2,o5,z5)){FileClose(f);Print("NORA_PHASE2_LAYER1_BATCH_FAIL_V1");return INIT_FAILED;}
for(int i=0;i<5;i++){string reason=!z5[i]?"ok":(n5[i]?"null_input":"warmup");string phase=!z5[i]?"steady_state":"warmup_or_null";FileWrite(f,"highest_null_window_p2","Highest","value",i,t5[i],z5[i]?"NULL":DoubleToString(o5[i],17),z5[i]?"true":"false",phase,reason);}double v6[6]={6,5,4,3,2,1};bool n6[6]={false,false,false,false,false,false};string t6[6]={"t0","t1","t2","t3","t4","t5"};double o6[];bool z6[];
if(!NoraLayer1Compute(2,v6,n6,6,3,o6,z6)){FileClose(f);Print("NORA_PHASE2_LAYER1_BATCH_FAIL_V1");return INIT_FAILED;}
for(int i=0;i<6;i++){string reason=!z6[i]?"ok":(n6[i]?"null_input":"warmup");string phase=!z6[i]?"steady_state":"warmup_or_null";FileWrite(f,"lowest_decreasing_p3","Lowest","value",i,t6[i],z6[i]?"NULL":DoubleToString(o6[i],17),z6[i]?"true":"false",phase,reason);}double v7[4]={0,0,0,0};bool n7[4]={false,false,false,false};string t7[4]={"t0","t1","t2","t3"};double o7[];bool z7[];
if(!NoraLayer1Compute(2,v7,n7,4,2,o7,z7)){FileClose(f);Print("NORA_PHASE2_LAYER1_BATCH_FAIL_V1");return INIT_FAILED;}
for(int i=0;i<4;i++){string reason=!z7[i]?"ok":(n7[i]?"null_input":"warmup");string phase=!z7[i]?"steady_state":"warmup_or_null";FileWrite(f,"lowest_zero_range_p2","Lowest","value",i,t7[i],z7[i]?"NULL":DoubleToString(o7[i],17),z7[i]?"true":"false",phase,reason);}FileWrite(f,"ema_invalid_period","EMA","value","NULL","NULL","NULL","true","invalid_input","invalid_period");FileWrite(f,"highest_invalid_period","Highest","value","NULL","NULL","NULL","true","invalid_input","invalid_period");FileWrite(f,"lowest_invalid_period","Lowest","value","NULL","NULL","NULL","true","invalid_input","invalid_period");
FileClose(f);Print("NORA_PHASE2_LAYER1_BATCH_COMPLETE_V1");return INIT_SUCCEEDED;}
