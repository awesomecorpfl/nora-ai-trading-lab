#property strict
#include "NoraPhase2AdxRuntimeV1.mqh"
int OnInit(){int f=FileOpen("nora_phase2_adx_v1.csv",FILE_WRITE|FILE_CSV|FILE_ANSI,'\t');if(f==INVALID_HANDLE){Print("NORA_PHASE2_ADX_FAIL_V1");return INIT_FAILED;}FileWrite(f,"scenario_id","node","output","row","timestamp","value","null","classification","reason_code");double h0[8]={10,11,12,13,14,15,16,17};double l0[8]={9,10,11,12,13,14,15,16};double c0[8]={9.5,10.5,11.5,12.5,13.5,14.5,15.5,16.5};string t0[8]={"2026-02-01T00:00:00Z","2026-02-01T00:01:00Z","2026-02-01T00:02:00Z","2026-02-01T00:03:00Z","2026-02-01T00:04:00Z","2026-02-01T00:05:00Z","2026-02-01T00:06:00Z","2026-02-01T00:07:00Z"};double a0[];bool v0[];
if(!NoraAdxCompute(h0,l0,c0,8,3,a0,v0)){FileClose(f);Print("NORA_PHASE2_ADX_FAIL_V1");return INIT_FAILED;}
for(int i=0;i<8;i++){FileWrite(f,"directional_trend","ADX","adx",i,t0[i],v0[i]?DoubleToString(a0[i],17):"NULL",v0[i]?"false":"true",v0[i]?"steady_state":"warmup_or_null",v0[i]?"ok":"warmup");}double h1[8]={10,12,11,13,12,14,15,14};double l1[8]={8,9,8,10,9,11,12,11};double c1[8]={9,11,9,12,10,13,14,12};string t1[8]={"2026-02-02T00:00:00Z","2026-02-02T00:01:00Z","2026-02-02T00:02:00Z","2026-02-02T00:03:00Z","2026-02-02T00:04:00Z","2026-02-02T00:05:00Z","2026-02-02T00:06:00Z","2026-02-02T00:07:00Z"};double a1[];bool v1[];
if(!NoraAdxCompute(h1,l1,c1,8,3,a1,v1)){FileClose(f);Print("NORA_PHASE2_ADX_FAIL_V1");return INIT_FAILED;}
for(int i=0;i<8;i++){FileWrite(f,"mixed_direction","ADX","adx",i,t1[i],v1[i]?DoubleToString(a1[i],17):"NULL",v1[i]?"false":"true",v1[i]?"steady_state":"warmup_or_null",v1[i]?"ok":"warmup");}double h2[5]={5,5,5,5,5};double l2[5]={5,5,5,5,5};double c2[5]={5,5,5,5,5};string t2[5]={"2026-02-03T00:00:00Z","2026-02-03T00:01:00Z","2026-02-03T00:02:00Z","2026-02-03T00:03:00Z","2026-02-03T00:04:00Z"};double a2[];bool v2[];
if(!NoraAdxCompute(h2,l2,c2,5,3,a2,v2)){FileClose(f);Print("NORA_PHASE2_ADX_FAIL_V1");return INIT_FAILED;}
for(int i=0;i<5;i++){FileWrite(f,"zero_denominator","ADX","adx",i,t2[i],v2[i]?DoubleToString(a2[i],17):"NULL",v2[i]?"false":"true",v2[i]?"steady_state":"warmup_or_null",v2[i]?"ok":"warmup");}FileWrite(f,"invalid_period","ADX","adx","NULL","NULL","NULL","true","invalid_input","invalid_period");FileClose(f);Print("NORA_PHASE2_ADX_COMPLETE_V1");return INIT_SUCCEEDED;}
void OnDeinit(const int reason){}
