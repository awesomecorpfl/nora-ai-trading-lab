#property strict
#include "NoraPhase2BollingerRuntimeV1.mqh"
int OnInit(){int f=FileOpen("nora_phase2_bollinger_v1.csv",FILE_WRITE|FILE_CSV|FILE_ANSI|FILE_COMMON,'\t');if(f==INVALID_HANDLE){Print("NORA_PHASE2_BOLLINGER_FAIL_V1");return INIT_FAILED;}FileWrite(f,"scenario_id","node","output","row","timestamp","value","null","classification","reason_code");double x0[5]={10,11,12,13,14};string t0[5]={"2026-06-01T00:00:00Z","2026-06-01T00:01:00Z","2026-06-01T00:02:00Z","2026-06-01T00:03:00Z","2026-06-01T00:04:00Z"};double v0[];bool ok0[];if(!NoraBollingerCompute(x0,5,3,2.0,0,v0,ok0)){FileClose(f);Print("NORA_PHASE2_BOLLINGER_FAIL_V1");return INIT_FAILED;}for(int j=0;j<5;j++){FileWrite(f,"bands_rising","Bollinger","middle",j,t0[j],ok0[j]?DoubleToString(v0[j],17):"NULL",ok0[j]?"false":"true",ok0[j]?"steady_state":"warmup_or_null",ok0[j]?"ok":"warmup");}double x1[5]={10,11,12,13,14};string t1[5]={"2026-06-01T00:00:00Z","2026-06-01T00:01:00Z","2026-06-01T00:02:00Z","2026-06-01T00:03:00Z","2026-06-01T00:04:00Z"};double v1[];bool ok1[];if(!NoraBollingerCompute(x1,5,3,2.0,1,v1,ok1)){FileClose(f);Print("NORA_PHASE2_BOLLINGER_FAIL_V1");return INIT_FAILED;}for(int j=0;j<5;j++){FileWrite(f,"bands_rising","Bollinger","upper",j,t1[j],ok1[j]?DoubleToString(v1[j],17):"NULL",ok1[j]?"false":"true",ok1[j]?"steady_state":"warmup_or_null",ok1[j]?"ok":"warmup");}double x2[5]={10,11,12,13,14};string t2[5]={"2026-06-01T00:00:00Z","2026-06-01T00:01:00Z","2026-06-01T00:02:00Z","2026-06-01T00:03:00Z","2026-06-01T00:04:00Z"};double v2[];bool ok2[];if(!NoraBollingerCompute(x2,5,3,2.0,2,v2,ok2)){FileClose(f);Print("NORA_PHASE2_BOLLINGER_FAIL_V1");return INIT_FAILED;}for(int j=0;j<5;j++){FileWrite(f,"bands_rising","Bollinger","lower",j,t2[j],ok2[j]?DoubleToString(v2[j],17):"NULL",ok2[j]?"false":"true",ok2[j]?"steady_state":"warmup_or_null",ok2[j]?"ok":"warmup");}double x3[5]={10,11,12,13,14};string t3[5]={"2026-06-01T00:00:00Z","2026-06-01T00:01:00Z","2026-06-01T00:02:00Z","2026-06-01T00:03:00Z","2026-06-01T00:04:00Z"};double v3[];bool ok3[];if(!NoraBollingerCompute(x3,5,3,2.0,3,v3,ok3)){FileClose(f);Print("NORA_PHASE2_BOLLINGER_FAIL_V1");return INIT_FAILED;}for(int j=0;j<5;j++){FileWrite(f,"bands_rising","Bollinger","width",j,t3[j],ok3[j]?DoubleToString(v3[j],17):"NULL",ok3[j]?"false":"true",ok3[j]?"steady_state":"warmup_or_null",ok3[j]?"ok":"warmup");}double x4[2]={0,0};string t4[2]={"2026-06-02T00:00:00Z","2026-06-02T00:01:00Z"};double v4[];bool ok4[];if(!NoraBollingerCompute(x4,2,2,2.0,3,v4,ok4)){FileClose(f);Print("NORA_PHASE2_BOLLINGER_FAIL_V1");return INIT_FAILED;}for(int j=0;j<2;j++){FileWrite(f,"flat_zero","Bollinger","width",j,t4[j],ok4[j]?DoubleToString(v4[j],17):"NULL",ok4[j]?"false":"true",ok4[j]?"steady_state":"warmup_or_null",ok4[j]?"ok":"warmup");}FileWrite(f,"invalid_period","Bollinger","middle","NULL","NULL","NULL","true","invalid_input","invalid_period");FileClose(f);Print("NORA_PHASE2_BOLLINGER_COMPLETE_V1");return INIT_SUCCEEDED;}
void OnDeinit(const int reason){}
