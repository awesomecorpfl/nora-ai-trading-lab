#property strict
#include "NoraPhase2LinearRegressionRuntimeV1.mqh"
int OnInit(){int f=FileOpen("nora_phase2_linear_regression_v1.csv",FILE_WRITE|FILE_CSV|FILE_ANSI,'\t');if(f==INVALID_HANDLE){Print("NORA_PHASE2_LINEAR_REGRESSION_FAIL_V1");return INIT_FAILED;}FileWrite(f,"scenario_id","node","output","row","timestamp","value","null","classification","reason_code");double x0[6]={2,4,6,8,10,12};string t0[6]={"2026-05-01T00:00:00Z","2026-05-01T00:01:00Z","2026-05-01T00:02:00Z","2026-05-01T00:03:00Z","2026-05-01T00:04:00Z","2026-05-01T00:05:00Z"};double v0[];double b0[];bool ok0[];if(!NoraLinearRegressionCompute(x0,6,3,v0,b0,ok0)){FileClose(f);Print("NORA_PHASE2_LINEAR_REGRESSION_FAIL_V1");return INIT_FAILED;}for(int j=0;j<6;j++){FileWrite(f,"rising_line","LinearRegression","value",j,t0[j],ok0[j]?DoubleToString(v0[j],17):"NULL",ok0[j]?"false":"true",ok0[j]?"steady_state":"warmup_or_null",ok0[j]?"ok":"warmup");}double x1[6]={2,4,6,8,10,12};string t1[6]={"2026-05-01T00:00:00Z","2026-05-01T00:01:00Z","2026-05-01T00:02:00Z","2026-05-01T00:03:00Z","2026-05-01T00:04:00Z","2026-05-01T00:05:00Z"};double v1[];double b1[];bool ok1[];if(!NoraLinearRegressionCompute(x1,6,3,v1,b1,ok1)){FileClose(f);Print("NORA_PHASE2_LINEAR_REGRESSION_FAIL_V1");return INIT_FAILED;}for(int j=0;j<6;j++){FileWrite(f,"rising_line","LinearRegression","slope",j,t1[j],ok1[j]?DoubleToString(b1[j],17):"NULL",ok1[j]?"false":"true",ok1[j]?"steady_state":"warmup_or_null",ok1[j]?"ok":"warmup");}double x2[6]={1,2,4,7,11,16};string t2[6]={"2026-05-02T00:00:00Z","2026-05-02T00:01:00Z","2026-05-02T00:02:00Z","2026-05-02T00:03:00Z","2026-05-02T00:04:00Z","2026-05-02T00:05:00Z"};double v2[];double b2[];bool ok2[];if(!NoraLinearRegressionCompute(x2,6,4,v2,b2,ok2)){FileClose(f);Print("NORA_PHASE2_LINEAR_REGRESSION_FAIL_V1");return INIT_FAILED;}for(int j=0;j<6;j++){FileWrite(f,"curved_series","LinearRegression","value",j,t2[j],ok2[j]?DoubleToString(v2[j],17):"NULL",ok2[j]?"false":"true",ok2[j]?"steady_state":"warmup_or_null",ok2[j]?"ok":"warmup");}FileWrite(f,"invalid_period","LinearRegression","value","NULL","NULL","NULL","true","invalid_input","invalid_period");FileClose(f);Print("NORA_PHASE2_LINEAR_REGRESSION_COMPLETE_V1");return INIT_SUCCEEDED;}
void OnDeinit(const int reason){}
