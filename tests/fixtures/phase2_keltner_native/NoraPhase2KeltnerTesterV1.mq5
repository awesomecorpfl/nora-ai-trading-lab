#property strict
#include "NoraPhase2KeltnerRuntimeV1.mqh"
int OnInit(){int f=FileOpen("nora_phase2_keltner_v1.csv",FILE_WRITE|FILE_CSV|FILE_ANSI|FILE_COMMON,'\t');if(f==INVALID_HANDLE){Print("NORA_PHASE2_KELTNER_FAIL_V1");return INIT_FAILED;}FileWrite(f,"scenario_id","node","output","row","timestamp","value","null","classification","reason_code");double h0[6]={11,13,14,16,17,19};double l0[6]={9,10,11,13,14,16};double c0[6]={10,12,13,15,16,18};string t0[6]={"2026-06-01T00:00:00Z","2026-06-01T00:01:00Z","2026-06-01T00:02:00Z","2026-06-01T00:03:00Z","2026-06-01T00:04:00Z","2026-06-01T00:05:00Z"};double v0[];bool q0[];if(!NoraKeltner(h0,l0,c0,6,3,2.0,0,v0,q0)){FileClose(f);Print("NORA_PHASE2_KELTNER_FAIL_V1");return INIT_FAILED;}for(int j=0;j<6;j++)FileWrite(f,"channel_rising","Keltner","middle",j,t0[j],q0[j]?DoubleToString(v0[j],17):"NULL",q0[j]?"false":"true",q0[j]?"steady_state":"warmup_or_null",q0[j]?"ok":"warmup");double h1[6]={11,13,14,16,17,19};double l1[6]={9,10,11,13,14,16};double c1[6]={10,12,13,15,16,18};string t1[6]={"2026-06-01T00:00:00Z","2026-06-01T00:01:00Z","2026-06-01T00:02:00Z","2026-06-01T00:03:00Z","2026-06-01T00:04:00Z","2026-06-01T00:05:00Z"};double v1[];bool q1[];if(!NoraKeltner(h1,l1,c1,6,3,2.0,1,v1,q1)){FileClose(f);Print("NORA_PHASE2_KELTNER_FAIL_V1");return INIT_FAILED;}for(int j=0;j<6;j++)FileWrite(f,"channel_rising","Keltner","upper",j,t1[j],q1[j]?DoubleToString(v1[j],17):"NULL",q1[j]?"false":"true",q1[j]?"steady_state":"warmup_or_null",q1[j]?"ok":"warmup");double h2[6]={11,13,14,16,17,19};double l2[6]={9,10,11,13,14,16};double c2[6]={10,12,13,15,16,18};string t2[6]={"2026-06-01T00:00:00Z","2026-06-01T00:01:00Z","2026-06-01T00:02:00Z","2026-06-01T00:03:00Z","2026-06-01T00:04:00Z","2026-06-01T00:05:00Z"};double v2[];bool q2[];if(!NoraKeltner(h2,l2,c2,6,3,2.0,2,v2,q2)){FileClose(f);Print("NORA_PHASE2_KELTNER_FAIL_V1");return INIT_FAILED;}for(int j=0;j<6;j++)FileWrite(f,"channel_rising","Keltner","lower",j,t2[j],q2[j]?DoubleToString(v2[j],17):"NULL",q2[j]?"false":"true",q2[j]?"steady_state":"warmup_or_null",q2[j]?"ok":"warmup");FileWrite(f,"invalid_period","Keltner","middle","NULL","NULL","NULL","true","invalid_input","invalid_period");FileClose(f);Print("NORA_PHASE2_KELTNER_COMPLETE_V1");return INIT_SUCCEEDED;}void OnDeinit(const int reason){}
