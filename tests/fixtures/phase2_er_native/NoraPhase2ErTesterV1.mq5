#property strict
#include "NoraPhase2ErRuntimeV1.mqh"
int OnInit(){int f=FileOpen("nora_phase2_er_v1.csv",FILE_WRITE|FILE_CSV|FILE_ANSI,'\t');if(f==INVALID_HANDLE){Print("NORA_PHASE2_ER_FAIL_V1");return INIT_FAILED;}FileWrite(f,"scenario_id","node","output","row","timestamp","value","null","classification","reason_code");double x0[6]={10,11,12,13,14,15};string t0[6]={"2026-03-01T00:00:00Z","2026-03-01T00:01:00Z","2026-03-01T00:02:00Z","2026-03-01T00:03:00Z","2026-03-01T00:04:00Z","2026-03-01T00:05:00Z"};double e0[];bool v0[];if(!NoraErCompute(x0,6,3,e0,v0)){FileClose(f);Print("NORA_PHASE2_ER_FAIL_V1");return INIT_FAILED;}for(int j=0;j<6;j++){FileWrite(f,"steady_trend","ER","er",j,t0[j],v0[j]?DoubleToString(e0[j],17):"NULL",v0[j]?"false":"true",v0[j]?"steady_state":"warmup_or_null",v0[j]?"ok":"warmup");}double x1[7]={10,12,11,13,12,14,13};string t1[7]={"2026-03-02T00:00:00Z","2026-03-02T00:01:00Z","2026-03-02T00:02:00Z","2026-03-02T00:03:00Z","2026-03-02T00:04:00Z","2026-03-02T00:05:00Z","2026-03-02T00:06:00Z"};double e1[];bool v1[];if(!NoraErCompute(x1,7,3,e1,v1)){FileClose(f);Print("NORA_PHASE2_ER_FAIL_V1");return INIT_FAILED;}for(int j=0;j<7;j++){FileWrite(f,"choppy_path","ER","er",j,t1[j],v1[j]?DoubleToString(e1[j],17):"NULL",v1[j]?"false":"true",v1[j]?"steady_state":"warmup_or_null",v1[j]?"ok":"warmup");}double x2[4]={7,7,7,7};string t2[4]={"2026-03-03T00:00:00Z","2026-03-03T00:01:00Z","2026-03-03T00:02:00Z","2026-03-03T00:03:00Z"};double e2[];bool v2[];if(!NoraErCompute(x2,4,3,e2,v2)){FileClose(f);Print("NORA_PHASE2_ER_FAIL_V1");return INIT_FAILED;}for(int j=0;j<4;j++){FileWrite(f,"zero_volatility","ER","er",j,t2[j],v2[j]?DoubleToString(e2[j],17):"NULL",v2[j]?"false":"true",v2[j]?"steady_state":"warmup_or_null",v2[j]?"ok":"warmup");}FileWrite(f,"invalid_period","ER","er","NULL","NULL","NULL","true","invalid_input","invalid_period");FileClose(f);Print("NORA_PHASE2_ER_COMPLETE_V1");return INIT_SUCCEEDED;}
void OnDeinit(const int reason){}
