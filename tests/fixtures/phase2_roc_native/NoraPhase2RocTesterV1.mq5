#property strict
#include "NoraPhase2RocRuntimeV1.mqh"
int OnInit(){int f=FileOpen("nora_phase2_roc_v1.csv",FILE_WRITE|FILE_CSV|FILE_ANSI,'\t');if(f==INVALID_HANDLE){Print("NORA_PHASE2_ROC_FAIL_V1");return INIT_FAILED;}FileWrite(f,"scenario_id","node","output","row","timestamp","value","null","classification","reason_code");double v0[5]={100,110,90,120,120};bool n0[5]={false,false,false,false,false};string t0[5]={"2042-02-01 00:00","2042-02-01 00:01","2042-02-01 00:02","2042-02-01 00:03","2042-02-01 00:04"};double o0[];bool z0[];if(!NoraRocCompute(v0,n0,5,2,o0,z0)){FileClose(f);Print("NORA_PHASE2_ROC_FAIL_V1");return INIT_FAILED;}for(int j=0;j<5;j++){string reason=z0[j]?(n0[j]?"null_input":(j<2?"warmup":"zero_baseline")):"ok";string phase=z0[j]?"warmup_or_null":"steady_state";FileWrite(f,"roc_ordinary_p2","ROC","value",j,t0[j],z0[j]?"NULL":DoubleToString(o0[j],17),z0[j]?"true":"false",phase,reason);}double v1[4]={0,10,20,30};bool n1[4]={false,false,false,false};string t1[4]={"2042-02-02 00:00","2042-02-02 00:01","2042-02-02 00:02","2042-02-02 00:03"};double o1[];bool z1[];if(!NoraRocCompute(v1,n1,4,2,o1,z1)){FileClose(f);Print("NORA_PHASE2_ROC_FAIL_V1");return INIT_FAILED;}for(int j=0;j<4;j++){string reason=z1[j]?(n1[j]?"null_input":(j<2?"warmup":"zero_baseline")):"ok";string phase=z1[j]?"warmup_or_null":"steady_state";FileWrite(f,"roc_zero_baseline_p2","ROC","value",j,t1[j],z1[j]?"NULL":DoubleToString(o1[j],17),z1[j]?"true":"false",phase,reason);}FileWrite(f,"roc_invalid_period","ROC","value","NULL","NULL","NULL","true","invalid_input","invalid_period");FileClose(f);Print("NORA_PHASE2_ROC_COMPLETE_V1");return INIT_SUCCEEDED;}
void OnDeinit(const int reason){}
