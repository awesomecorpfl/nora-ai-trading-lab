#property strict
#include "NoraPhase2CCIRuntimeV1.mqh"
int OnInit(){int f=FileOpen("nora_phase2_cci_v1.csv",FILE_WRITE|FILE_CSV|FILE_ANSI|FILE_COMMON,'\t');if(f==INVALID_HANDLE){Print("NORA_PHASE2_CCI_FAIL_V1");return INIT_FAILED;}FileWrite(f,"scenario_id","node","output","row","timestamp","value","null","classification","reason_code");double h0[6]={11,12,13,14,15,16};double l0[6]={9,10,11,12,13,14};double c0[6]={10,11,12,13,14,15};string t0[6]={"2026-06-01T00:00:00Z","2026-06-01T00:01:00Z","2026-06-01T00:02:00Z","2026-06-01T00:03:00Z","2026-06-01T00:04:00Z","2026-06-01T00:05:00Z"};double v0[];bool ok0[];if(!NoraCCICompute(h0,l0,c0,6,3,v0,ok0)){FileClose(f);Print("NORA_PHASE2_CCI_FAIL_V1");return INIT_FAILED;}for(int j=0;j<6;j++){FileWrite(f,"linear_typical_price","CCI","value",j,t0[j],ok0[j]?DoubleToString(v0[j],17):"NULL",ok0[j]?"false":"true",ok0[j]?"steady_state":"warmup_or_null",ok0[j]?"ok":"warmup");}double h1[4]={7,7,7,7};double l1[4]={7,7,7,7};double c1[4]={7,7,7,7};string t1[4]={"2026-06-02T00:00:00Z","2026-06-02T00:01:00Z","2026-06-02T00:02:00Z","2026-06-02T00:03:00Z"};double v1[];bool ok1[];if(!NoraCCICompute(h1,l1,c1,4,3,v1,ok1)){FileClose(f);Print("NORA_PHASE2_CCI_FAIL_V1");return INIT_FAILED;}for(int j=0;j<4;j++){FileWrite(f,"flat_market","CCI","value",j,t1[j],ok1[j]?DoubleToString(v1[j],17):"NULL",ok1[j]?"false":"true",ok1[j]?"steady_state":"warmup_or_null",ok1[j]?"ok":"warmup");}FileWrite(f,"invalid_period","CCI","value","NULL","NULL","NULL","true","invalid_input","invalid_period");FileClose(f);Print("NORA_PHASE2_CCI_COMPLETE_V1");return INIT_SUCCEEDED;}
void OnDeinit(const int reason){}
